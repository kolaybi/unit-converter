{
    "name": "kolaybi/unit-converter",
    "description": "A PHP 8.4+ unit conversion package compatible with UN/CEFACT Recommendation 20",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "unit",
        "converter",
        "conversion",
        "measurement",
        "uncefact",
        "rec20",
        "gs1",
        "e-document",
        "e-fatura",
        "bcmath"
    ],
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "KolayBi\\UnitConverter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KolayBi\\UnitConverter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "pint": "./vendor/bin/pint --dirty --parallel"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
